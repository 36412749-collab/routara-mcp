{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.36412749-collab/routara-mcp",
  "title": "Routara LLM Gateway",
  "description": "OpenAI-compatible LLM, image and video APIs via Routara (api.routara.ai).",
  "repository": {
    "url": "https://github.com/36412749-collab/routara-mcp",
    "source": "github"
  },
  "version": "1.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "routara-mcp",
      "version": "1.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ROUTARA_API_KEY",
          "description": "Routara API key (sk-or-v1-...) from https://routara.ai/#auth",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "ROUTARA_API_BASE",
          "description": "Optional API base URL (default https://api.routara.ai/v1)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "ROUTARA_API_TIMEOUT_MS",
          "description": "Optional request timeout in milliseconds (default 30000)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
